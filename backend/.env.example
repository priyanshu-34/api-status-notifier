# Database (MongoDB)
MONGODB_URI=mongodb://localhost:27017/api_status_notifier
# Or use DATABASE_URL (same value) - both are supported
# DATABASE_URL=mongodb://localhost:27017/api_status_notifier

# Server
PORT=3000

# JWT (auth)
JWT_SECRET=change-this-to-a-random-secret-in-production
JWT_EXPIRES_IN=604800

# Notifications (optional - leave empty to disable)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
NOTIFY_EMAIL=
WEBHOOK_URL=

# Invitation emails (set FRONTEND_URL for invite links in emails)
FRONTEND_URL=http://localhost:5173

# Feature flags (true/false)
ENABLE_EMAIL_NOTIFICATIONS=false
ENABLE_WEBHOOK_NOTIFICATIONS=false

# Cooldown between notifications for same endpoint (minutes)
NOTIFICATION_COOLDOWN_MINUTES=15
